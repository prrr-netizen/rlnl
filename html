<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>RLNL Studio</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-950 text-slate-50">
  <main>
    <!-- 상단 네비 -->
    <header class="border-b border-slate-800">
      <div class="max-w-5xl mx-auto flex items-center justify-between py-4 px-4">
        <div class="font-bold text-lg">RLNL Studio</div>
        <nav class="flex gap-4 text-sm text-slate-300">
          <a href="#features">기능</a>
          <a href="#stats">통계</a>
          <a href="#links">링크</a>
        </nav>
      </div>
    </header>

    <!-- Hero 섹션 -->
    <section class="max-w-5xl mx-auto px-4 py-16">
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4">
        디스코드 경제·게임 올인원 봇, RLNL
      </h1>
      <p class="text-slate-300 mb-6">
        블랙잭, 상점, 은행 시스템까지 한 번에 관리하는 디스코드 전용 봇입니다.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="디스코드_초대_URL"
          class="px-4 py-2 rounded-md bg-violet-500 hover:bg-violet-600 text-sm font-medium"
        >
          디스코드에 초대하기
        </a>
        <a
          href="#commands"
          class="px-4 py-2 rounded-md border border-slate-600 text-sm font-medium"
        >
          명령어 보기
        </a>
      </div>
    </section>

    <!-- 통계 섹션 -->
    <section id="stats" class="max-w-5xl mx-auto px-4 pb-16">
      <h2 class="text-xl font-semibold mb-4">📈 성장 기록</h2>
      <ul class="space-y-1 text-slate-300 text-sm">
        <li>2026. 03 : 누적 000 서버 돌파</li>
        <li>2026. 02 : 베타 테스트 시작</li>
        <li>2025. 12 : RLNL 첫 공개</li>
      </ul>
    </section>

    <!-- 기능 섹션 -->
    <section id="features" class="max-w-5xl mx-auto px-4 pb-16">
      <h2 class="text-xl font-semibold mb-4">✨ 주요 기능</h2>
      <div class="grid md:grid-cols-3 gap-4 text-sm text-slate-300">
        <div class="border border-slate-800 rounded-lg p-4">
          <h3 class="font-semibold mb-2">🎰 블랙잭 게임</h3>
          <p>서버 전용 경제 시스템과 연동되는 카드 게임.</p>
        </div>
        <div class="border border-slate-800 rounded-lg p-4">
          <h3 class="font-semibold mb-2">🛒 상점 / 자판기</h3>
          <p>크레딧으로 아이템을 사고 파는 상점 시스템.</p>
        </div>
        <div class="border border-slate-800 rounded-lg p-4">
          <h3 class="font-semibold mb-2">🏦 은행 / 대출</h3>
          <p>크레딧 잔액·대출을 관리하는 은행 시스템.</p>
        </div>
      </div>
    </section>

    <!-- 링크 섹션 -->
    <section id="links" class="max-w-5xl mx-auto px-4 pb-16">
      <h2 class="text-xl font-semibold mb-4">🔗 링크</h2>
      <ul class="space-y-2 text-sm text-slate-300">
        <li>
          디스코드 봇 초대:
          <a class="text-violet-400" href="초대링크">초대하기</a>
        </li>
        <li>
          지원 서버:
          <a class="text-violet-400" href="지원서버링크">참여하기</a>
        </li>
      </ul>
    </section>

    <!-- 푸터 -->
    <footer class="border-t border-slate-800">
      <div class="max-w-5xl mx-auto px-4 py-4 text-xs text-slate-500">
        © <span id="year"></span> RLNL Studio. All rights reserved.
      </div>
    </footer>
  </main>

  <script>
    // 연도 자동 표시
    document.getElementById("year").textContent = new Date().getFullYear();
  </script>
</body>
</html>
